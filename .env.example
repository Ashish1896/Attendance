# ============================================================
# Smart Attendance System — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# --- Supabase ---
# Get from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- App Config ---
APP_NAME=Smart Attendance System
APP_SECRET_KEY=generate-a-strong-random-secret-key-here
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"

# --- Face Recognition ---
FACE_MATCH_THRESHOLD=0.5
# Lower = more strict (0.4 recommended for high accuracy)
# Higher = more lenient (0.6 max recommended)

# --- JWT ---
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# --- Admin Bootstrap ---
# First admin user created on first run
ADMIN_EMAIL=admin@school.edu
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=System Administrator
